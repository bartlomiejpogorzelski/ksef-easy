<%= render 'account/shared/page' do |page| %>
  <% page.title t('.section') %>
  <% page.body do %>
    <%= cable_ready_updates_for @invoice do %>
      <%= render 'account/shared/box', divider: true do |box| %>
        <% box.title t('.header') %>
        <% box.description do %>
          <%= t('.description') %>
          <%= t('.manage_description') if can? :manage, @invoice %>
        <% end %>

        <% box.body do %>
          <% with_attribute_settings object: @invoice, strategy: :label do %>
            <%= render 'shared/attributes/text', attribute: :number %>
            <%= render 'shared/attributes/date', attribute: :issue_date %>
            <%= render 'shared/attributes/date', attribute: :sale_date %>
            <%= render 'shared/attributes/date', attribute: :payment_date %>
            <%= render 'shared/attributes/number', attribute: :netto %>
            <%= render 'shared/attributes/number', attribute: :vat_rate %>
            <%= render 'shared/attributes/number', attribute: :vat %>
            <%= render 'shared/attributes/number', attribute: :brutto %>
            <%= render 'shared/attributes/text', attribute: :status %>
            <%= render 'shared/attributes/text', attribute: :buyer_nip %>
            <%= render 'shared/attributes/text', attribute: :buyer_name %>
            <%= render 'shared/attributes/text', attribute: :seller %>
            <%= render 'shared/attributes/text', attribute: :description %>
            <%# 🚅 super scaffolding will insert new fields above this line. %>
          <% end %>
        <% end %>

        <% box.actions do %>
          <%= link_to t('.buttons.edit'), [:edit, :account, @invoice], class: first_button_primary if can? :edit, @invoice %>
          <%# 🚅 super scaffolding will insert new action model buttons above this line. %>
          <%= button_to t('.buttons.destroy'), [:account, @invoice], method: :delete, class: first_button_primary, data: { turbo_confirm: t('.buttons.confirmations.destroy', model_locales(@invoice)) } if can? :destroy, @invoice %>
          <%= link_to t('global.buttons.back'), [:account, @team, :invoices], class: first_button_primary %>
        <% end %>

        <% box.raw_footer do %>
          <%# 🚅 super scaffolding will insert new action model index views above this line. %>
        <% end %>
      <% end %>
    <% end %>

    <%# 🚅 super scaffolding will insert new children above this line. %>
  <% end %>
<% end %>
