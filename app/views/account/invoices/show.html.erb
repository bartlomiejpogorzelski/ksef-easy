<%= render 'account/shared/page' do |page| %>
  <% page.title t('.section') %>
  <% page.body do %>
    <%= cable_ready_updates_for @invoice do %>
      <%= render 'account/shared/box', divider: true do |box| %>
        <% box.title t('.header') %>
        <% box.description do %>
          <%= t('.description') %>
          <%= t('.manage_description') if can? :manage, @invoice %>
        <% end %>

        <% box.body do %>
          <div class="space-y-6">
            <div>
              <div class="text-sm font-medium text-gray-500">Numer faktury</div>
              <div class="mt-1 text-lg font-semibold"><%= @invoice.number %></div>
            </div>

            <div class="grid grid-cols-2 gap-x-8 gap-y-6">
              <div>
                <div class="text-sm font-medium text-gray-500">Data wystawienia</div>
                <div class="mt-1"><%= l(@invoice.issue_date) if @invoice.issue_date %></div>
              </div>
              <div>
                <div class="text-sm font-medium text-gray-500">Data sprzedaży</div>
                <div class="mt-1"><%= l(@invoice.sale_date) if @invoice.sale_date %></div>
              </div>
            </div>

            <div class="grid grid-cols-2 gap-x-8 gap-y-6">
              <div>
                <div class="text-sm font-medium text-gray-500">Netto</div>
                <div class="mt-1 text-lg font-semibold text-green-600"><%= format_money(@invoice.netto) %></div>
              </div>
              <div>
                <div class="text-sm font-medium text-gray-500">Stawka VAT</div>
                <div class="mt-1 text-lg font-semibold"><%= @invoice.vat_rate %> %</div>
              </div>
            </div>

            <div class="grid grid-cols-2 gap-x-8 gap-y-6">
              <div>
                <div class="text-sm font-medium text-gray-500">VAT</div>
                <div class="mt-1 text-lg font-semibold text-green-600"><%= format_money(@invoice.vat) %></div>
              </div>
              <div>
                <div class="text-sm font-medium text-gray-500">Brutto</div>
                <div class="mt-1 text-lg font-semibold text-green-600"><%= format_money(@invoice.brutto) %></div>
              </div>
            </div>

            <div>
              <div class="text-sm font-medium text-gray-500">Status</div>
              <div class="mt-1 font-medium"><%= @invoice.status %></div>
            </div>

            <div>
              <div class="text-sm font-medium text-gray-500">NIP nabywcy</div>
              <div class="mt-1"><%= @invoice.buyer_nip %></div>
            </div>

            <div>
              <div class="text-sm font-medium text-gray-500">Nazwa nabywcy</div>
              <div class="mt-1"><%= @invoice.buyer_name %></div>
            </div>

            <div>
              <div class="text-sm font-medium text-gray-500">Sprzedawca</div>
              <div class="mt-1"><%= @invoice.seller %></div>
            </div>

            <% if @invoice.description.present? %>
            <div>
              <div class="text-sm font-medium text-gray-500">Opis</div>
              <div class="mt-1 text-gray-700"><%= @invoice.description %></div>
            </div>
            <% end %>
          </div>          

          <!-- === Attachment to inovice === -->
          <% if @invoice.document.attached? %>
            <div class="mt-8 border-t border-gray-200 pt-8">
              <h3 class="text-lg font-medium text-gray-900 mb-4">Załączona faktura</h3>
              <div class="flex items-center gap-x-4 bg-gray-50 p-4 rounded-lg border border-gray-200">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-10 w-10 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2 2 2 0 01-2-2 2 2 0 012-2 2 2 0 01-2-2z" />
                </svg>
                <div class="flex-1 min-w-0">
                  <p class="font-medium text-gray-900 truncate"><%= @invoice.document.filename %></p>
                  <p class="text-sm text-gray-500">
                    <%= number_to_human_size(@invoice.document.byte_size) %> • dodano <%= time_ago_in_words(@invoice.document.created_at) %> temu
                  </p>
                </div>
                <div>
                  <%= link_to "Pobierz plik", 
                              rails_blob_path(@invoice.document, disposition: "attachment"), 
                              class: "inline-flex items-center px-5 py-2.5 bg-indigo-600 text-white text-sm font-medium rounded-lg hover:bg-indigo-700 transition-colors" %>
                </div>
              </div>
            </div>
          <% end %>

        <% end %>

        <% box.actions do %>
          <%= link_to t('.buttons.edit'), [:edit, :account, @invoice], class: first_button_primary if can? :edit, @invoice %>
          <%= button_to t('.buttons.destroy'), [:account, @invoice], method: :delete, class: first_button_primary, data: { turbo_confirm: t('.buttons.confirmations.destroy', model_locales(@invoice)) } if can? :destroy, @invoice %>
          <%= link_to t('global.buttons.back'), [:account, @team, :invoices], class: first_button_primary %>
        <% end %>

        <% box.raw_footer do %>
          <%# 🚅 super scaffolding will insert new action model index views above this line. %>
        <% end %>
      <% end %>
    <% end %>

    <%# 🚅 super scaffolding will insert new children above this line. %>
  <% end %>
<% end %>