<% if flash[:notice] %>
  <div class="bg-emerald-50 border border-emerald-200 text-emerald-800 px-6 py-4 rounded-2xl mb-8 flex items-center gap-3">
    <span class="text-2xl">✅</span>
    <p class="font-medium"><%= flash[:notice] %></p>
  </div>
<% end %>

<% if flash[:alert] || flash[:error] %>
  <div class="bg-red-50 border border-red-200 text-red-800 px-6 py-4 rounded-2xl mb-8">
    <%= flash[:alert] || flash[:error] %>
  </div>
<% end %>